// 领域→概念 包含关系
MATCH (d:Domain {id: 'programming'}), (c:Concept {domain_id: 'programming'})
CREATE (d)-[:CONTAINS]->(c);

// 子域→概念 包含关系
MATCH (s:Subdomain), (c:Concept)
WHERE s.id = c.subdomain_id
CREATE (s)-[:CONTAINS]->(c);

// 创建索引
CREATE INDEX concept_id IF NOT EXISTS FOR (c:Concept) ON (c.id);
CREATE INDEX concept_domain IF NOT EXISTS FOR (c:Concept) ON (c.domain_id);
CREATE INDEX concept_subdomain IF NOT EXISTS FOR (c:Concept) ON (c.subdomain_id);
CREATE INDEX domain_id IF NOT EXISTS FOR (d:Domain) ON (d.id);
CREATE INDEX subdomain_id IF NOT EXISTS FOR (s:Subdomain) ON (s.id);